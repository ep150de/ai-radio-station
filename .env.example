# Suno Radio — Environment Configuration
# Copy to .env and adjust. Docker Compose automatically loads this.

# Core paths (inside container)
MUSIC_DIR=/music
DATA_DIR=/data

# Server
PORT=8080
STATION_NAME=Beacon FM
LOG_LEVEL=info

# Playback
CROSSFADE_MS=300
DEFAULT_SHUFFLE=true          # Shuffle catalog once on first run (recommended for non-repeating feel)

# Phase 2 (future)
# PIPER_URL=http://piper:5000
# TTS_PROVIDER=piper          # or "openai" or "webspeech" (client fallback)
# OPENAI_API_KEY=sk-...
# OPENAI_TTS_VOICE=nova

# Optional: bind host music path for reference only (not used inside containers)
# HOST_MUSIC_PATH=/home/lingleblater/Music/suno-library
